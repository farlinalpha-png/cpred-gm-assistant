{
  "name": "cpred-gm-assistant",
  "version": "3.5.0",
  "description": "Cyberpunk RED GM & Character Assistant",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "publish": "electron-builder --publish always",
    "dev": "electron . --dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/farlinalpha-png/cpred-gm-assistant.git"
  },
  "build": {
    "appId": "com.nightcity.cpred-assistant",
    "productName": "CP:RED GM Assistant",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "farlinalpha-png",
      "repo": "cpred-gm-assistant"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CP:RED GM Assistant"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["universal"] },
        { "target": "zip", "arch": ["universal"] }
      ],
      "icon": "assets/icon-512.png",
      "category": "public.app-category.utilities",
      "identity": null
    },
    "dmg": {
      "title": "CP:RED GM Assistant ${version}"
    },
    "files": [
      "src/**/*",
      "public/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "player-app/**/*",
      "android-app/**/*"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ]
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "author": "Night City Systems",
  "license": "MIT",
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
